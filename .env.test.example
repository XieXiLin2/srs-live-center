# ============================================================
#  Oryx Live Center - 测试环境配置
#  此文件仅用于本地开发和测试，不要在生产环境使用
# ============================================================

# ===== App Settings =====
APP_NAME=Oryx Live Center (Dev)
APP_SECRET_KEY=test-secret-key-do-not-use-in-production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ===== Database =====
# SQLite (默认，开箱即用)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== OAuth2 — Mock OAuth2 Server =====
# 指向本地 Mock OAuth2 服务器 (mock-oauth/)
# 启动方式: cd mock-oauth && pip install -r requirements.txt && python server.py
# 管理页面: http://localhost:9000/manage
# 预置用户: admin/admin (管理员), user1/user1, user2/user2
OAUTH2_CLIENT_ID=test-client
OAUTH2_CLIENT_SECRET=test-secret
OAUTH2_AUTHORIZE_URL=http://localhost:9000/authorize
OAUTH2_TOKEN_URL=http://localhost:9000/token
OAUTH2_USERINFO_URL=http://localhost:9000/userinfo
OAUTH2_LOGOUT_URL=http://localhost:9000/end-session
OAUTH2_REDIRECT_URI=http://localhost:5173/auth/callback
OAUTH2_SCOPE=openid profile email
OAUTH2_ADMIN_GROUP=oryx-admin

# ===== Oryx/SRS =====
# 本地 Oryx 实例 (默认端口 2022)
ORYX_API_URL=http://localhost:2022
ORYX_API_SECRET=
ORYX_HTTP_URL=http://localhost:2022

# ===== CDN =====
# 留空表示不使用 CDN，媒体流通过后端反向代理
CDN_BASE_URL=
CDN_PULL_SECRET=

# ===== JWT =====
JWT_SECRET=test-jwt-secret-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== Docker Compose 额外变量 =====
# WebRTC CANDIDATE IP (填写服务器公网 IP)
CANDIDATE=127.0.0.1
# Oryx 管理密码
ORYX_MGMT_PASSWORD=test-password
