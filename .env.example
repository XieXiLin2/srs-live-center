# ===== SRS Live Center Configuration =====
# Copy this file to .env and fill in the values.

# App
APP_NAME=SRS Live Center
APP_SECRET_KEY=change-me-in-production
DEBUG=false
ALLOWED_ORIGINS=http://localhost

# Base URL as seen by the end user (through Nginx).
# Leave empty for single-container / dev. Example: https://live.example.com
PUBLIC_BASE_URL=

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Redis
REDIS_URL=redis://redis:6379/0

# OAuth2 / Authentik
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_AUTHORIZE_URL=https://auth.example.com/application/o/authorize/
OAUTH2_TOKEN_URL=https://auth.example.com/application/o/token/
OAUTH2_USERINFO_URL=https://auth.example.com/application/o/userinfo/
OAUTH2_LOGOUT_URL=https://auth.example.com/application/o/end-session/
OAUTH2_REDIRECT_URI=http://localhost/auth/callback
OAUTH2_SCOPE=openid profile email
OAUTH2_ADMIN_GROUP=srs-admin

# ===== SRS 6 (direct integration, no Oryx) =====
SRS_HTTP_URL=http://srs:8080
SRS_API_URL=http://srs:1985
SRS_APP=live
# Optional shared secret for SRS http_hooks URLs; if set, SRS must append
# ?hook_secret=<value> to the callback URLs.
SRS_HOOK_SECRET=

# WebRTC playback (WHEP) global kill-switch.
# - true  → frontend may offer WebRTC as a play option (per-room can still disable)
# - false → all rooms refuse WebRTC play; WebRTC publish (WHIP) is unaffected
WEBRTC_PLAY_ENABLED=true

# For WebRTC: the public IP of the SRS host (needed in srs.conf candidate).
CANDIDATE=

# JWT
JWT_SECRET=change-me-jwt-secret-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
