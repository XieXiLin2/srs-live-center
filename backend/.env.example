# ===== App Settings =====
APP_NAME=SRS Live Center
APP_SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# The public base URL clients use to reach the Nginx front-door.
# Leave empty to use relative URLs (single-container dev mode).
# Example: https://live.example.com
PUBLIC_BASE_URL=

# ===== Database =====
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== OAuth2 / Authentik =====
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_AUTHORIZE_URL=https://auth.example.com/application/o/authorize/
OAUTH2_TOKEN_URL=https://auth.example.com/application/o/token/
OAUTH2_USERINFO_URL=https://auth.example.com/application/o/userinfo/
OAUTH2_LOGOUT_URL=https://auth.example.com/application/o/end-session/
OAUTH2_REDIRECT_URI=http://localhost:5173/auth/callback
OAUTH2_SCOPE=openid profile email
OAUTH2_ADMIN_GROUP=srs-admin

# ===== SRS 6 (direct integration, no Oryx) =====
# Internal HTTP server (HTTP-FLV) — default SRS port 8080.
SRS_HTTP_URL=http://srs:8080
# Internal HTTP API — default SRS port 1985.
SRS_API_URL=http://srs:1985
# Stream app name (the path segment between host and stream id).
SRS_APP=live
# Shared secret in SRS http_hooks URLs; e.g. configure hooks as:
#   http://app:8000/api/hooks/on_publish?hook_secret=xxx
SRS_HOOK_SECRET=

# WebRTC playback (WHEP) global kill-switch.
# When false, `/api/streams/` never advertises WebRTC and `/api/streams/play`
# rejects format=webrtc. WebRTC publish (WHIP) is unaffected.
WEBRTC_PLAY_ENABLED=true

# ===== JWT =====
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
